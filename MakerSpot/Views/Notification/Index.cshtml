@model IEnumerable<MakerSpot.Models.Notification>
@{
    ViewData["Title"] = "Thông báo";
    var unreadCount = Model.Count(n => !n.IsRead);
}

<div class="row justify-content-center">
    <div class="col-lg-7">

        <!-- Header -->
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h1 class="h4 fw-bold mb-0">
                    <i class="bi bi-bell me-2" style="color:var(--ph-orange);"></i>Thông báo
                </h1>
                @if (unreadCount > 0)
                {
                    <small class="text-muted">@unreadCount chưa đọc</small>
                }
            </div>
            @if (unreadCount > 0)
            {
                <form asp-action="MarkAllAsRead" method="post">
                    <button type="submit" class="btn btn-sm border fw-semibold" style="font-size:.8rem;background:#fff;">
                        <i class="bi bi-check2-all me-1"></i>Đánh dấu tất cả đã đọc
                    </button>
                </form>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="card border-0 empty-state text-center">
                <i class="bi bi-bell-slash"></i>
                <h5>Chưa có thông báo nào</h5>
                <p>Mọi hoạt động sẽ hiển thị ở đây.</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary mx-auto" style="width:fit-content;">Khám phá sản phẩm</a>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-2 fade-in">
                @foreach (var n in Model)
                {
                    <div class="card border-0 @(!n.IsRead ? "" : "")"
                         style="@(!n.IsRead ? "border-left:3px solid var(--ph-orange)!important;" : "")">
                        <div class="card-body p-3 d-flex align-items-center gap-3">
                            <!-- Icon -->
                            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width:40px;height:40px;background:@(n.Type == "NewUpvote" ? "#fff3f2" : n.Type == "NewComment" ? "#f0fdf4" : "#eff6ff");">
                                @switch (n.Type)
                                {
                                    case "NewUpvote":
                                        <i class="bi bi-caret-up-fill" style="color:var(--ph-orange);"></i>
                                        break;
                                    case "NewComment":
                                        <i class="bi bi-chat-fill" style="color:#16a34a;"></i>
                                        break;
                                    case "NewFollower":
                                        <i class="bi bi-person-plus-fill" style="color:#2563eb;"></i>
                                        break;
                                    default:
                                        <i class="bi bi-bell-fill text-muted"></i>
                                        break;
                                }
                            </div>
                            <!-- Content -->
                            <div class="flex-grow-1 min-w-0">
                                <p class="mb-0 @(!n.IsRead ? "fw-semibold" : "")" style="font-size:.9rem;color:#1f2937;">@n.Message</p>
                                <small class="text-muted">@n.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                            <!-- Action -->
                            @if (!n.IsRead)
                            {
                                <form asp-action="MarkAsRead" asp-route-id="@n.NotificationId" method="post" class="flex-shrink-0">
                                    <button type="submit" class="btn btn-sm rounded-circle border d-flex align-items-center justify-content-center"
                                            style="width:30px;height:30px;background:#fff;" title="Đánh dấu đã đọc">
                                        <i class="bi bi-check2" style="font-size:.8rem;"></i>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted flex-shrink-0" style="font-size:.75rem;">Đã đọc</span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

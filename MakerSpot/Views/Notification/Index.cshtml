@model IEnumerable<MakerSpot.Models.Notification>

@{
    ViewData["Title"] = "Thông báo";
}

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
            <h4 class="fw-bold mb-0"><i class="bi bi-bell me-2"></i>Thông báo</h4>
            @if (Model.Any(n => !n.IsRead))
            {
                <form asp-action="MarkAllAsRead" method="post">
                    <button type="submit" class="btn btn-outline-primary btn-sm fw-bold">
                        <i class="bi bi-check2-all me-1"></i>Đánh dấu tất cả đã đọc
                    </button>
                </form>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5 border rounded bg-light">
                <i class="bi bi-bell-slash fs-1"></i>
                <p class="mt-2">Chưa có thông báo nào.</p>
            </div>
        }
        else
        {
            <div class="list-group shadow-sm">
                @foreach (var n in Model)
                {
                    <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-start border-0 @(!n.IsRead ? "bg-primary bg-opacity-10" : "")">
                        <div class="ms-2 me-auto">
                            <div class="d-flex align-items-center mb-1">
                                @switch (n.Type)
                                {
                                    case "NewUpvote":
                                        <i class="bi bi-caret-up-fill text-primary me-2 fs-5"></i>
                                        break;
                                    case "NewComment":
                                        <i class="bi bi-chat-fill text-success me-2 fs-5"></i>
                                        break;
                                    case "NewFollower":
                                        <i class="bi bi-person-plus-fill text-info me-2 fs-5"></i>
                                        break;
                                    default:
                                        <i class="bi bi-bell-fill text-muted me-2 fs-5"></i>
                                        break;
                                }
                                <span class="@(!n.IsRead ? "fw-bold" : "")">@n.Message</span>
                            </div>
                            <small class="text-muted">@n.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                        @if (!n.IsRead)
                        {
                            <form asp-action="MarkAsRead" asp-route-id="@n.NotificationId" method="post" class="ms-2">
                                <button type="submit" class="btn btn-outline-secondary btn-sm" title="Đánh dấu đã đọc">
                                    <i class="bi bi-check2"></i>
                                </button>
                            </form>
                        }
                        else
                        {
                            <span class="badge bg-light text-muted border mt-1">Đã đọc</span>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

@model MakerSpot.ViewModels.UserProfileViewModel
@{
    ViewData["Title"] = $"Hồ sơ {Model.User.FullName}";
    bool isOwn = User.Identity!.IsAuthenticated && User.Identity.Name == Model.User.Username;
}

<div class="row g-4">
    <!-- ===== LEFT: User Card ===== -->
    <div class="col-lg-3 col-md-4">
        <div class="sidebar-sticky">
            <div class="card border-0 p-4 text-center">
                <!-- Avatar -->
                @if (!string.IsNullOrEmpty(Model.User.AvatarUrl))
                {
                    <img src="@Model.User.AvatarUrl" alt="@Model.User.FullName"
                         class="rounded-circle mx-auto mb-3 border"
                         style="width:100px;height:100px;object-fit:cover;"
                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
                }
                <div class="avatar mx-auto mb-3 @(!string.IsNullOrEmpty(Model.User.AvatarUrl) ? "d-none" : "")"
                     style="width:100px;height:100px;font-size:2.5rem;">
                    @Model.User.FullName.Substring(0, 1).ToUpper()
                </div>

                <h2 class="h5 fw-bold mb-0">@Model.User.FullName</h2>
                <p class="text-muted mb-3" style="font-size:.875rem;">@@@Model.User.Username</p>

                @if (!string.IsNullOrEmpty(Model.User.Bio))
                {
                    <p class="text-muted mb-3" style="font-size:.875rem;line-height:1.5;">@Model.User.Bio</p>
                }

                <!-- Follow button -->
                @if (!isOwn && User.Identity.IsAuthenticated)
                {
                    <form asp-controller="Follow" asp-action="Toggle" method="post" class="mb-3">
                        <input type="hidden" name="followingId" value="@Model.User.UserId" />
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                        <button type="submit" class="btn @(Model.IsFollowing ? "border fw-semibold" : "btn-primary fw-semibold") w-100"
                                style="@(Model.IsFollowing ? "background:#fff;" : "")">
                            @if (Model.IsFollowing)
                            {
                                <i class="bi bi-person-check me-1"></i><text>Đang theo dõi</text>
                            }
                            else
                            {
                                <i class="bi bi-person-plus me-1"></i><text>Theo dõi</text>
                            }
                        </button>
                    </form>
                }

                <!-- Stats -->
                <div class="d-flex justify-content-around pt-3 border-top">
                    <div>
                        <div class="fw-bold">@Model.SubmittedProducts.Count(p => p.Status == "Approved")</div>
                        <div class="text-muted" style="font-size:.78rem;">Sản phẩm</div>
                    </div>
                    <div>
                        <div class="fw-bold">@Model.FollowerCount</div>
                        <div class="text-muted" style="font-size:.78rem;">Followers</div>
                    </div>
                    <div>
                        <div class="fw-bold">@Model.FollowingCount</div>
                        <div class="text-muted" style="font-size:.78rem;">Following</div>
                    </div>
                </div>

                <!-- Social links -->
                @if (!string.IsNullOrEmpty(Model.User.WebsiteUrl) || !string.IsNullOrEmpty(Model.User.TwitterUrl) || !string.IsNullOrEmpty(Model.User.LinkedinUrl))
                {
                    <div class="d-flex gap-3 justify-content-center mt-3 pt-3 border-top">
                        @if (!string.IsNullOrEmpty(Model.User.WebsiteUrl))
                        {
                            <a href="@Model.User.WebsiteUrl" target="_blank" class="text-muted text-decoration-none" title="Website">
                                <i class="bi bi-globe2 fs-5"></i>
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(Model.User.TwitterUrl))
                        {
                            <a href="@Model.User.TwitterUrl" target="_blank" class="text-muted text-decoration-none" title="Twitter/X">
                                <i class="bi bi-twitter-x fs-5"></i>
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(Model.User.LinkedinUrl))
                        {
                            <a href="@Model.User.LinkedinUrl" target="_blank" class="text-muted text-decoration-none" title="LinkedIn">
                                <i class="bi bi-linkedin fs-5"></i>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ===== RIGHT: Tabs ===== -->
    <div class="col-lg-9 col-md-8">
        <ul class="nav nav-tabs mb-4" id="profileTabs">
            <li class="nav-item">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-products">
                    Sản phẩm <span class="badge ms-1" style="background:#f3f4f6;color:#6b7280;">@Model.SubmittedProducts.Count</span>
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-upvoted">
                    Đã Upvote <span class="badge ms-1" style="background:#f3f4f6;color:#6b7280;">@Model.UpvotedProducts.Count</span>
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-collections">
                    Collections <span class="badge ms-1" style="background:#f3f4f6;color:#6b7280;">@Model.Collections.Count</span>
                </button>
            </li>
        </ul>

        <div class="tab-content fade-in">
            <!-- Products Tab -->
            <div class="tab-pane fade show active" id="tab-products">
                @if (!Model.SubmittedProducts.Any())
                {
                    <div class="card border-0 empty-state text-center">
                        <i class="bi bi-box"></i>
                        <h5>Chưa có sản phẩm nào</h5>
                        <p>@(isOwn ? "Bạn chưa gửi sản phẩm nào." : "Người dùng này chưa đăng sản phẩm.")</p>
                        @if (isOwn)
                        {
                            <a asp-controller="Product" asp-action="Submit" class="btn btn-primary mx-auto" style="width:fit-content;">Gửi sản phẩm</a>
                        }
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var p in Model.SubmittedProducts)
                        {
                            <div class="card border-0 product-card">
                                <div class="card-body p-3 d-flex align-items-center gap-3">
                                    @if (p.Status == "Pending")
                                    {
                                        <span class="position-absolute top-0 end-0 m-2 status-badge status-pending">Chờ duyệt</span>
                                    }
                                    <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.ProductId" class="flex-shrink-0">
                                        <img src="@(string.IsNullOrEmpty(p.LogoUrl) ? "/images/default-logo.png" : p.LogoUrl)"
                                             class="product-logo" style="width:52px;height:52px;"
                                             onerror="this.src='https://placehold.co/52x52';" />
                                    </a>
                                    <div class="flex-grow-1 min-w-0 hover-title">
                                        <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.ProductId" class="text-decoration-none">
                                            <h6 class="fw-bold mb-0" style="color:#1f2937;font-size:.95rem;">@p.ProductName</h6>
                                            <p class="text-muted mb-0 mt-1 small">@p.Tagline</p>
                                        </a>
                                    </div>
                                    <div class="text-center flex-shrink-0">
                                        <div class="fw-bold" style="color:var(--ph-orange);">@p.UpvoteCount</div>
                                        <small class="text-muted">upvotes</small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Upvoted Tab -->
            <div class="tab-pane fade" id="tab-upvoted">
                @if (!Model.UpvotedProducts.Any())
                {
                    <div class="card border-0 empty-state text-center">
                        <i class="bi bi-heart"></i>
                        <h5>Chưa upvote sản phẩm nào</h5>
                        <p>Khám phá và upvote những sản phẩm bạn thích.</p>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var p in Model.UpvotedProducts)
                        {
                            <div class="card border-0 product-card">
                                <div class="card-body p-3 d-flex align-items-center gap-3">
                                    <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.ProductId" class="flex-shrink-0">
                                        <img src="@(string.IsNullOrEmpty(p.LogoUrl) ? "/images/default-logo.png" : p.LogoUrl)"
                                             class="product-logo" style="width:52px;height:52px;" />
                                    </a>
                                    <div class="flex-grow-1 hover-title">
                                        <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.ProductId" class="text-decoration-none">
                                            <h6 class="fw-bold mb-0" style="color:#1f2937;font-size:.95rem;">@p.ProductName</h6>
                                            <p class="text-muted mb-0 mt-1 small">@p.Tagline</p>
                                        </a>
                                    </div>
                                    <div class="text-center flex-shrink-0">
                                        <div class="fw-bold" style="color:var(--ph-orange);">@p.UpvoteCount</div>
                                        <small class="text-muted">upvotes</small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Collections Tab -->
            <div class="tab-pane fade" id="tab-collections">
                @if (isOwn)
                {
                    <div class="d-flex justify-content-end mb-3">
                        <a asp-controller="Collection" asp-action="Create" class="btn btn-primary fw-semibold btn-sm px-3">
                            <i class="bi bi-plus me-1"></i>Tạo Collection
                        </a>
                    </div>
                }
                @if (!Model.Collections.Any())
                {
                    <div class="card border-0 empty-state text-center">
                        <i class="bi bi-collection"></i>
                        <h5>Chưa có collection nào</h5>
                        <p>@(isOwn ? "Tạo collection để lưu sản phẩm yêu thích." : "Người dùng này chưa có collection công khai.")</p>
                    </div>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var col in Model.Collections)
                        {
                            <div class="col-sm-6">
                                <a asp-controller="Collection" asp-action="Detail" asp-route-id="@col.CollectionId"
                                   class="text-decoration-none d-block h-100">
                                    <div class="card border-0 h-100 product-card">
                                        <div class="card-body p-3">
                                            <div class="d-flex align-items-start gap-2 mb-2">
                                                <i class="bi bi-collection" style="color:var(--ph-orange);margin-top:2px;"></i>
                                                <div>
                                                    <h6 class="fw-bold mb-0 text-dark">@col.CollectionName</h6>
                                                    @if (!string.IsNullOrEmpty(col.Description))
                                                    {
                                                        <p class="text-muted small mb-0 mt-1">@col.Description</p>
                                                    }
                                                </div>
                                            </div>
                                            <div class="d-flex justify-content-between align-items-center mt-2">
                                                <small class="text-muted">@col.CollectionItems.Count sản phẩm</small>
                                                @if (!col.IsPublic)
                                                {
                                                    <span class="badge" style="background:#f3f4f6;color:#6b7280;"><i class="bi bi-lock me-1"></i>Riêng tư</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

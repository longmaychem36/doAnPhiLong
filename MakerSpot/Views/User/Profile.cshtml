@model MakerSpot.ViewModels.UserProfileViewModel

@{
    ViewData["Title"] = $"Hồ sơ {Model.User.FullName}";
    bool isOwnProfile = User.Identity!.IsAuthenticated && User.Identity.Name == Model.User.Username;
}

<div class="row mt-4 mb-5">
    <!-- User Info Card -->
    <div class="col-md-4 mb-4">
        <div class="card border-0 shadow-sm text-center p-4 sticky-top" style="top: 80px;">
            <img src="@(string.IsNullOrEmpty(Model.User.AvatarUrl) ? "/images/default-avatar.png" : Model.User.AvatarUrl)" 
                 alt="@Model.User.FullName" class="rounded-circle mx-auto mb-3 border object-fit-cover" 
                 style="width: 120px; height: 120px;" onerror="this.src='https://via.placeholder.com/120?text=U';"/>
            
            <h4 class="fw-bold mb-1">@Model.User.FullName</h4>
            <p class="text-muted mb-3">@@@Model.User.Username</p>
            
            @if (!string.IsNullOrEmpty(Model.User.Bio))
            {
                <p class="small text-secondary mb-3">@Model.User.Bio</p>
            }
            
            @if (!isOwnProfile && User.Identity.IsAuthenticated)
            {
                <form asp-controller="Follow" asp-action="Toggle" method="post" class="mb-3">
                    <input type="hidden" name="followingId" value="@Model.User.UserId" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                    @if (Model.IsFollowing)
                    {
                        <button type="submit" class="btn btn-outline-primary btn-sm rounded-pill px-4">
                            <i class="bi bi-person-check-fill me-1"></i>Đang theo dõi
                        </button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-primary btn-sm rounded-pill px-4">
                            <i class="bi bi-person-plus me-1"></i>Theo dõi
                        </button>
                    }
                </form>
            }

            <div class="d-flex justify-content-center gap-3 mb-3">
                @if (!string.IsNullOrEmpty(Model.User.WebsiteUrl))
                {
                    <a href="@Model.User.WebsiteUrl" target="_blank" class="text-muted text-decoration-none" title="Website"><i class="bi bi-globe fs-5"></i></a>
                }
                @if (!string.IsNullOrEmpty(Model.User.TwitterUrl))
                {
                    <a href="@Model.User.TwitterUrl" target="_blank" class="text-muted text-decoration-none" title="Twitter"><i class="bi bi-twitter-x fs-5"></i></a>
                }
                @if (!string.IsNullOrEmpty(Model.User.LinkedinUrl))
                {
                    <a href="@Model.User.LinkedinUrl" target="_blank" class="text-muted text-decoration-none" title="LinkedIn"><i class="bi bi-linkedin fs-5"></i></a>
                }
            </div>
            
            <hr class="my-3">
            
            <div class="d-flex justify-content-around text-center">
                <div>
                    <h6 class="fw-bold mb-0">@Model.SubmittedProducts.Count(p => p.Status == "Approved")</h6>
                    <small class="text-muted">Sản phẩm</small>
                </div>
                <div>
                    <h6 class="fw-bold mb-0">@Model.FollowerCount</h6>
                    <small class="text-muted">Followers</small>
                </div>
                <div>
                    <h6 class="fw-bold mb-0">@Model.FollowingCount</h6>
                    <small class="text-muted">Following</small>
                </div>
            </div>
        </div>
    </div>

    <!-- User Activity Tabs -->
    <div class="col-md-8">
        <ul class="nav nav-tabs mb-4" id="profileTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active fw-bold text-dark" id="submitted-tab" data-bs-toggle="tab" data-bs-target="#submitted" type="button" role="tab">
                    Sản phẩm <span class="badge bg-secondary ms-1">@Model.SubmittedProducts.Count</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold text-dark" id="upvoted-tab" data-bs-toggle="tab" data-bs-target="#upvoted" type="button" role="tab">
                    Đã Upvote <span class="badge bg-secondary ms-1">@Model.UpvotedProducts.Count</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold text-dark" id="collections-tab" data-bs-toggle="tab" data-bs-target="#collections" type="button" role="tab">
                    Collections <span class="badge bg-secondary ms-1">@Model.Collections.Count</span>
                </button>
            </li>
        </ul>

        <div class="tab-content" id="profileTabsContent">
            <!-- Submitted Products Tab -->
            <div class="tab-pane fade show active" id="submitted" role="tabpanel">
                @if (!Model.SubmittedProducts.Any())
                {
                    <div class="text-center text-muted py-5 border rounded bg-light">
                        <i class="bi bi-box fs-1"></i>
                        <p class="mt-2">Chưa có sản phẩm nào.</p>
                        @if (isOwnProfile)
                        {
                            <a asp-controller="Product" asp-action="Submit" class="btn btn-primary mt-2">Nộp sản phẩm mới</a>
                        }
                    </div>
                }
                else
                {
                    @foreach (var product in Model.SubmittedProducts)
                    {
                        <div class="card product-card mb-3 border-0 shadow-sm position-relative">
                            @if (product.Status == "Pending")
                            {
                                <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2 rounded-1">Pending</span>
                            }
                            <div class="card-body p-3 d-flex align-items-center">
                                <a asp-controller="Product" asp-action="Detail" asp-route-id="@product.ProductId" class="text-decoration-none d-flex flex-grow-1 align-items-center text-dark">
                                    <img src="@(string.IsNullOrEmpty(product.LogoUrl) ? "/images/default-logo.png" : product.LogoUrl)" alt="Logo" class="product-logo me-3 rounded" style="width: 60px; height: 60px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/60?text=Logo';" />
                                    <div>
                                        <h5 class="card-title fw-bold mb-1">@product.ProductName</h5>
                                        <p class="card-text text-muted mb-1 fs-6">@product.Tagline</p>
                                        <div>
                                            @foreach (var pt in product.ProductTopics)
                                            {
                                                <span class="badge bg-light text-secondary border fw-normal me-1">@pt.Topic.TopicName</span>
                                            }
                                        </div>
                                    </div>
                                </a>
                                <div class="d-flex flex-column align-items-end ms-3">
                                    <span class="btn btn-light border d-flex flex-column align-items-center px-3 py-1 mb-2">
                                        <i class="bi bi-caret-up-fill text-muted"></i>
                                        <span class="fw-bold">@product.UpvoteCount</span>
                                    </span>
                                    <span class="text-muted small"><i class="bi bi-chat-fill me-1"></i>@product.CommentCount</span>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Upvoted Products Tab -->
            <div class="tab-pane fade" id="upvoted" role="tabpanel">
                @if (!Model.UpvotedProducts.Any())
                {
                    <div class="text-center text-muted py-5 border rounded bg-light">
                        <i class="bi bi-heart fs-1"></i>
                        <p class="mt-2">Chưa upvote sản phẩm nào.</p>
                    </div>
                }
                else
                {
                    @foreach (var product in Model.UpvotedProducts)
                    {
                        <div class="card product-card mb-3 border-0 shadow-sm">
                            <div class="card-body p-3 d-flex align-items-center">
                                <a asp-controller="Product" asp-action="Detail" asp-route-id="@product.ProductId" class="text-decoration-none d-flex flex-grow-1 align-items-center text-dark">
                                    <img src="@(string.IsNullOrEmpty(product.LogoUrl) ? "/images/default-logo.png" : product.LogoUrl)" alt="Logo" class="product-logo me-3 rounded" style="width: 60px; height: 60px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/60?text=Logo';" />
                                    <div>
                                        <h5 class="card-title fw-bold mb-1">@product.ProductName</h5>
                                        <p class="card-text text-muted mb-1 fs-6">@product.Tagline</p>
                                        <div>
                                            @foreach (var pt in product.ProductTopics)
                                            {
                                                <span class="badge bg-light text-secondary border fw-normal me-1">@pt.Topic.TopicName</span>
                                            }
                                        </div>
                                    </div>
                                </a>
                                <div class="d-flex flex-column align-items-end ms-3">
                                    <span class="btn btn-light border d-flex flex-column align-items-center px-3 py-1 mb-2">
                                        <i class="bi bi-caret-up-fill text-primary"></i>
                                        <span class="fw-bold">@product.UpvoteCount</span>
                                    </span>
                                    <span class="text-muted small"><i class="bi bi-chat-fill me-1"></i>@product.CommentCount</span>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Collections Tab -->
            <div class="tab-pane fade" id="collections" role="tabpanel">
                @if (isOwnProfile)
                {
                    <div class="mb-3 text-end">
                        <a asp-controller="Collection" asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Tạo Collection mới</a>
                    </div>
                }
                @if (!Model.Collections.Any())
                {
                    <div class="text-center text-muted py-5 border rounded bg-light">
                        <i class="bi bi-collection fs-1"></i>
                        <p class="mt-2">Chưa có collection nào.</p>
                    </div>
                }
                else
                {
                    <div class="row">
                        @foreach (var col in Model.Collections)
                        {
                            <div class="col-md-6 mb-3">
                                <a asp-controller="Collection" asp-action="Detail" asp-route-id="@col.CollectionId" class="text-decoration-none">
                                    <div class="card border-0 shadow-sm h-100">
                                        <div class="card-body">
                                            <h6 class="fw-bold text-dark mb-1">
                                                <i class="bi bi-collection me-1"></i>@col.CollectionName
                                            </h6>
                                            <p class="text-muted small mb-2">@col.Description</p>
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span class="text-muted small">@col.CollectionItems.Count sản phẩm</span>
                                                @if (!col.IsPublic)
                                                {
                                                    <span class="badge bg-secondary small"><i class="bi bi-lock me-1"></i>Riêng tư</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

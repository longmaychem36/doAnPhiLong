@model MakerSpot.ViewModels.ProductDetailViewModel
@{
    ViewData["Title"] = Model.Product.ProductName;
}

<div class="row g-4 mt-0">
    <!-- ===== MAIN ===== -->
    <div class="col-lg-8">

        <!-- Product Header -->
        <div class="d-flex align-items-start gap-3 mb-4">
            <img src="@(string.IsNullOrEmpty(Model.Product.LogoUrl) ? "/images/default-logo.png" : Model.Product.LogoUrl)"
                 alt="@Model.Product.ProductName"
                 class="product-logo flex-shrink-0"
                 style="width:80px;height:80px;"
                 onerror="this.src='https://placehold.co/80x80/f3f4f6/9ca3af?text=🚀';" />
            <div class="flex-grow-1 min-w-0">
                <h1 class="h2 fw-bold mb-1">@Model.Product.ProductName</h1>
                <p class="text-muted mb-2" style="font-size:1.05rem;">@Model.Product.Tagline</p>
                <div class="d-flex flex-wrap gap-1">
                    @foreach (var pt in Model.Product.ProductTopics)
                    {
                        <a asp-controller="Home" asp-action="Index" asp-route-topic="@pt.Topic.Slug"
                           class="topic-badge">@pt.Topic.TopicName</a>
                    }
                </div>
            </div>
            <!-- Upvote -->
            <div class="flex-shrink-0">
                <form asp-controller="Product" asp-action="Upvote" method="post">
                    <input type="hidden" name="productId" value="@Model.Product.ProductId" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                    <button type="submit" class="btn-upvote btn d-flex flex-column align-items-center @(Model.HasUpvoted ? "active" : "")" style="min-width:64px;">
                        <i class="bi bi-caret-up-fill" style="font-size:1.3rem;"></i>
                        <span style="font-size:.95rem;">@Model.Product.UpvoteCount</span>
                    </button>
                </form>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="d-flex gap-2 mb-4">
            <a href="@Model.Product.WebsiteUrl" target="_blank" rel="noopener" class="btn btn-primary fw-semibold px-4">
                Truy cập website <i class="bi bi-box-arrow-up-right ms-1"></i>
            </a>
            @if (!string.IsNullOrEmpty(Model.Product.DemoUrl))
            {
                <a href="@Model.Product.DemoUrl" target="_blank" rel="noopener" class="btn border fw-semibold px-4" style="background:#fff;">
                    <i class="bi bi-play-circle me-1"></i>Demo
                </a>
            }
            @if(User.Identity != null && User.Identity.IsAuthenticated)
            {
                <button type="button" class="btn border fw-semibold px-4 text-dark" style="background:#fff;" data-bs-toggle="modal" data-bs-target="#shareChatModal" onclick="loadConversations()">
                    <i class="bi bi-share me-1"></i>Chia sẻ vào Chat
                </button>
            }
        </div>

        <!-- Media Gallery -->
        @if (Model.Product.ProductMedia.Any())
        {
            <div id="mediaCarousel" class="carousel slide mb-5 rounded-3 overflow-hidden shadow-sm" data-bs-ride="carousel">
                @{var mediaList = Model.Product.ProductMedia.ToList();}
                <div class="carousel-inner" style="max-height:420px;">
                    @for (int i = 0; i < mediaList.Count; i++)
                    {
                        var mediaItem = mediaList[i];
                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            @if (mediaItem.MediaType == "Video")
                            {
                                <div class="bg-dark d-flex flex-column align-items-center justify-content-center text-center py-5" style="height:420px;">
                                    <i class="bi bi-play-circle text-white-50 mb-3" style="font-size:4rem;"></i>
                                    <a href="@mediaItem.MediaUrl" target="_blank" class="btn btn-outline-light">Xem video</a>
                                </div>
                            }
                            else
                            {
                                <img src="@mediaItem.MediaUrl" class="d-block w-100" alt="Screenshot @(i+1)"
                                     style="object-fit:contain;background:#f9fafb;height:420px;"
                                     onerror="this.src='https://placehold.co/800x420/f9fafb/d1d5db?text=No+Image';">
                            }
                        </div>
                    }
                </div>
                @if (mediaList.Count > 1)
                {
                    <div class="carousel-indicators mb-0">
                        @for (int i = 0; i < mediaList.Count; i++)
                        {
                            <button type="button" data-bs-target="#mediaCarousel" data-bs-slide-to="@i"
                                    class="@(i == 0 ? "active" : "")" style="border-radius:50%;width:8px;height:8px;"></button>
                        }
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#mediaCarousel" data-bs-slide="prev">
                        <span class="bg-dark rounded-circle p-2 d-flex" style="opacity:.7;"><i class="bi bi-chevron-left text-white"></i></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#mediaCarousel" data-bs-slide="next">
                        <span class="bg-dark rounded-circle p-2 d-flex" style="opacity:.7;"><i class="bi bi-chevron-right text-white"></i></span>
                    </button>
                }
            </div>
        }

        <!-- Description -->
        <div class="mb-5">
            <h2 class="h5 fw-bold mb-3">Giới thiệu sản phẩm</h2>
            <div class="text-muted lh-lg" style="white-space:pre-wrap;font-size:.95rem;">@Model.Product.Description</div>
        </div>

        <!-- Comments -->
        <div class="border-top pt-4">
            <h2 class="h5 fw-bold mb-4">
                Thảo luận <span class="text-muted fw-normal" style="font-size:.9rem;">(@Model.Product.CommentCount)</span>
            </h2>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="d-flex gap-3 mb-4">
                    <div class="avatar flex-shrink-0" style="width:36px;height:36px;">@User.Identity.Name.Substring(0,1).ToUpper()</div>
                    <div class="flex-grow-1">
                        <form asp-controller="Product" asp-action="PostComment" method="post">
                            <input type="hidden" name="productId" value="@Model.Product.ProductId" />
                            <textarea name="content" class="form-control mb-2" rows="2"
                                      placeholder="Chia sẻ ý kiến của bạn..." required></textarea>
                            <div class="text-end">
                                <button type="submit" class="btn btn-primary fw-semibold px-4">Gửi bình luận</button>
                            </div>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 text-center py-4 mb-4" style="background:#f9fafb;">
                    <p class="text-muted mb-2">Đăng nhập để tham gia thảo luận</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <a asp-controller="Auth" asp-action="Login" class="btn btn-primary fw-semibold px-4">Đăng nhập</a>
                        <a asp-controller="Auth" asp-action="Register" class="btn border fw-semibold px-4">Đăng ký</a>
                    </div>
                </div>
            }

            <!-- Comment list -->
            @if (!Model.Product.Comments.Any())
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-chat d-block mb-2" style="font-size:2rem;color:#d1d5db;"></i>
                    Chưa có bình luận nào. Hãy là người đầu tiên!
                </div>
            }

            <div class="d-flex flex-column gap-4">
                @{ 
                    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                    bool isAdminOrMod = User.IsInRole("Admin") || User.IsInRole("Moderator");
                }
                @foreach (var comment in Model.Product.Comments)
                {
                    <div class="d-flex gap-3">
                        <img src="@(string.IsNullOrEmpty(comment.User.AvatarUrl) ? "" : comment.User.AvatarUrl)"
                             class="rounded-circle flex-shrink-0 border" style="width:36px;height:36px;object-fit:cover;"
                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
                        <div class="avatar flex-shrink-0" style="width:36px;height:36px;display:none;">@comment.User.FullName.Substring(0,1).ToUpper()</div>
                        <div class="flex-grow-1">
                            <div class="comment-bubble mb-2">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <a asp-controller="User" asp-action="Profile" asp-route-username="@comment.User.Username"
                                       class="fw-bold text-decoration-none" style="color:#1f2937;font-size:.9rem;">@comment.User.FullName</a>
                                    <span class="text-muted" style="font-size:.8rem;">@comment.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                    @if (comment.IsEdited)
                                    {
                                        <span class="text-muted fst-italic" style="font-size:.75rem;">(đã chỉnh sửa)</span>
                                    }
                                </div>
                                <p class="mb-0" style="font-size:.9rem;line-height:1.6;">@comment.Content</p>
                            </div>
                            @* Comment action buttons *@
                            <div class="d-flex align-items-center gap-3" style="font-size:.8rem;">
                                @if (User.Identity != null && User.Identity.IsAuthenticated)
                                {
                                    @* Vote button *@
                                    <form asp-controller="Product" asp-action="VoteComment" method="post" class="d-inline">
                                        <input type="hidden" name="commentId" value="@comment.CommentId" />
                                        <input type="hidden" name="productId" value="@Model.Product.ProductId" />
                                        <button type="submit" class="btn btn-sm p-0 text-muted fw-semibold" style="border:none;background:none;">
                                            <i class="bi bi-hand-thumbs-up me-1"></i>@comment.CommentVotes.Count
                                        </button>
                                    </form>

                                    @* Reply button *@
                                    <button class="btn btn-sm fw-semibold p-0 text-muted text-decoration-none"
                                            onclick="document.getElementById('reply-@comment.CommentId').classList.toggle('d-none')"
                                            style="background:none;border:none;">
                                        <i class="bi bi-reply me-1"></i>Trả lời
                                    </button>
                                    
                                    @* Edit/Delete (chỉ chủ comment hoặc Admin/Mod) *@
                                    @if (currentUserId == comment.UserId.ToString() || isAdminOrMod)
                                    {
                                        <button class="btn btn-sm fw-semibold p-0 text-muted"
                                                onclick="document.getElementById('edit-@comment.CommentId').classList.toggle('d-none')"
                                                style="background:none;border:none;">
                                            <i class="bi bi-pencil me-1"></i>Sửa
                                        </button>
                                        <form asp-controller="Product" asp-action="DeleteComment" method="post" class="d-inline"
                                              onsubmit="return confirm('Bạn chắc chắn muốn xóa bình luận này?');">
                                            <input type="hidden" name="commentId" value="@comment.CommentId" />
                                            <input type="hidden" name="productId" value="@Model.Product.ProductId" />
                                            <button type="submit" class="btn btn-sm fw-semibold p-0 text-danger" style="background:none;border:none;">
                                                <i class="bi bi-trash me-1"></i>Xóa
                                            </button>
                                        </form>
                                    }
                                }
                            </div>

                            @* Edit form (ẩn mặc định) *@
                            @if (User.Identity != null && User.Identity.IsAuthenticated && (currentUserId == comment.UserId.ToString() || isAdminOrMod))
                            {
                                <div id="edit-@comment.CommentId" class="d-none mt-2">
                                    <form asp-controller="Product" asp-action="EditComment" method="post" class="d-flex gap-2">
                                        <input type="hidden" name="commentId" value="@comment.CommentId" />
                                        <input type="hidden" name="productId" value="@Model.Product.ProductId" />
                                        <textarea name="content" class="form-control form-control-sm flex-grow-1" rows="2">@comment.Content</textarea>
                                        <button type="submit" class="btn btn-primary btn-sm fw-semibold">Lưu</button>
                                    </form>
                                </div>
                            }

                            @* Reply form *@
                            @if (User.Identity != null && User.Identity.IsAuthenticated)
                            {
                                <div id="reply-@comment.CommentId" class="d-none mt-2">
                                    <form asp-controller="Product" asp-action="PostComment" method="post" class="d-flex gap-2">
                                        <input type="hidden" name="productId" value="@Model.Product.ProductId" />
                                        <input type="hidden" name="parentCommentId" value="@comment.CommentId" />
                                        <textarea name="content" class="form-control form-control-sm flex-grow-1" rows="1"
                                                  placeholder="Viết phản hồi..." required></textarea>
                                        <button type="submit" class="btn btn-primary btn-sm fw-semibold">Gửi</button>
                                    </form>
                                </div>
                            }

                            <!-- Replies -->
                            @if (comment.Replies.Any())
                            {
                                <div class="reply-thread mt-3 d-flex flex-column gap-3">
                                    @foreach (var reply in comment.Replies)
                                    {
                                        <div class="d-flex gap-2">
                                            <div class="avatar flex-shrink-0" style="width:28px;height:28px;font-size:.75rem;">@reply.User.FullName.Substring(0,1).ToUpper()</div>
                                            <div class="flex-grow-1">
                                                <div class="comment-bubble" style="border-radius:0 8px 8px 8px;padding:.6rem .9rem;">
                                                    <span class="fw-bold me-2" style="font-size:.85rem;color:#1f2937;">@reply.User.FullName</span>
                                                    <span class="text-muted" style="font-size:.78rem;">@reply.CreatedAt.ToString("dd/MM/yyyy")</span>
                                                    @if (reply.IsEdited) { <span class="text-muted fst-italic" style="font-size:.72rem;">(đã chỉnh sửa)</span> }
                                                    <p class="mb-0 mt-1" style="font-size:.88rem;">@reply.Content</p>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ===== SIDEBAR ===== -->
    <div class="col-lg-4">
        <div class="sidebar-sticky d-flex flex-column gap-3">

            <!-- Makers -->
            @if (Model.Product.ProductMakers.Any())
            {
                <div class="card border-0">
                    <div class="card-body p-4">
                        <h6 class="label-heading mb-3" style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--ph-muted);">Makers</h6>
                        @foreach (var pm in Model.Product.ProductMakers)
                        {
                            <a asp-controller="User" asp-action="Profile" asp-route-username="@pm.User.Username"
                               class="d-flex align-items-center gap-2 text-decoration-none mb-3">
                                <div class="avatar" style="width:38px;height:38px;font-size:.9rem;">@pm.User.FullName.Substring(0,1).ToUpper()</div>
                                <div>
                                    <div class="fw-semibold" style="font-size:.9rem;color:#1f2937;">@pm.User.FullName</div>
                                    <small class="text-muted">@pm.MakerRole</small>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }

            <!-- Info -->
            <div class="card border-0">
                <div class="card-body p-4">
                    <h6 class="mb-3" style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--ph-muted);">Thông tin</h6>
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                            <span class="text-muted" style="font-size:.875rem;">Ngày ra mắt</span>
                            <span class="fw-semibold" style="font-size:.875rem;">@(Model.Product.LaunchDate?.ToString("dd/MM/yyyy") ?? "—")</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                            <span class="text-muted" style="font-size:.875rem;">Lượt xem</span>
                            <span class="fw-semibold" style="font-size:.875rem;">@Model.Product.ViewCount.ToString("N0")</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center py-2">
                            <span class="text-muted" style="font-size:.875rem;">Upvotes</span>
                            <span class="fw-semibold" style="font-size:.875rem;">@Model.Product.UpvoteCount</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Add to Collection -->
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="card border-0">
                    <div class="card-body p-4">
                        <h6 class="mb-3" style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--ph-muted);">Lưu vào Collection</h6>
                        @if (Model.UserCollections != null && Model.UserCollections.Any())
                        {
                            <form asp-controller="Collection" asp-action="AddItem" method="post">
                                <input type="hidden" name="productId" value="@Model.Product.ProductId" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                <div class="d-flex gap-2">
                                    <select name="collectionId" class="form-select form-select-sm flex-grow-1">
                                        @foreach (var col in Model.UserCollections)
                                        {
                                            <option value="@col.CollectionId">@col.CollectionName</option>
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-primary btn-sm fw-semibold px-3">
                                        <i class="bi bi-plus"></i>
                                    </button>
                                </div>
                            </form>
                        }
                        else
                        {
                            <div class="text-center">
                                <p class="text-muted small mb-2">Bạn chưa có collection nào.</p>
                                <a asp-controller="Collection" asp-action="Create" class="btn btn-sm border fw-semibold w-100">
                                    <i class="bi bi-plus me-1"></i>Tạo Collection
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }

            @* Report sản phẩm *@
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="card border-0">
                    <div class="card-body p-4">
                        <h6 class="mb-3" style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--ph-muted);">Báo cáo vi phạm</h6>
                        <form asp-controller="Report" asp-action="Submit" method="post">
                            <input type="hidden" name="targetType" value="Product" />
                            <input type="hidden" name="targetId" value="@Model.Product.ProductId" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                            <select name="reason" class="form-select form-select-sm mb-2" required>
                                <option value="">Chọn lý do...</option>
                                <option value="Spam">Spam / Quảng cáo</option>
                                <option value="Nội dung không phù hợp">Nội dung không phù hợp</option>
                                <option value="Vi phạm bản quyền">Vi phạm bản quyền</option>
                                <option value="Thông tin sai lệch">Thông tin sai lệch</option>
                                <option value="Khác">Khác</option>
                            </select>
                            <textarea name="description" class="form-control form-control-sm mb-2" rows="2"
                                      placeholder="Mô tả thêm (tùy chọn)..."></textarea>
                            <button type="submit" class="btn btn-outline-danger btn-sm fw-semibold w-100">
                                <i class="bi bi-flag me-1"></i>Gửi báo cáo
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal Chia Sẻ Chat -->
<div class="modal fade" id="shareChatModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold">Chia sẻ sản phẩm này</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label text-muted small fw-bold">Lời nhắn (tuỳ chọn)</label>
                    <textarea id="shareMessageContent" class="form-control" rows="2" placeholder="Gửi cho bạn bè xem thử nha..."></textarea>
                </div>
                <label class="form-label text-muted small fw-bold mb-2">Chọn cuộc trò chuyện</label>
                <div id="conversationsList" class="list-group list-group-flush border rounded-3 overflow-auto" style="max-height: 250px;">
                    <div class="text-center p-3 text-muted" id="convLoading"><span class="spinner-border spinner-border-sm me-2"></span>Đang tải...</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function loadConversations() {
            const list = document.getElementById('conversationsList');
            list.innerHTML = '<div class="text-center p-3 text-muted"><span class="spinner-border spinner-border-sm me-2"></span>Đang tải...</div>';
            
            fetch('/Chat/GetMyConversations')
                .then(r => r.json())
                .then(data => {
                    list.innerHTML = '';
                    if (!data || data.length === 0) {
                        list.innerHTML = '<div class="p-3 text-center text-muted small">Không tìm thấy cuộc trò chuyện nào để chia sẻ. Hãy nhắn tin trước nhé!</div>';
                        return;
                    }
                    data.forEach(c => {
                        const btn = document.createElement('button');
                        btn.className = "list-group-item list-group-item-action d-flex align-items-center gap-2 py-2";
                        const avatar = c.avatarUrl || '/images/default-avatar.png';
                        btn.innerHTML = `
                            <img src="${avatar}" style="width:32px;height:32px;border-radius:50%;object-fit:cover;">
                            <span class="fw-semibold flex-grow-1 text-start">${c.otherUser}</span>
                            <span class="btn btn-sm btn-primary rounded-pill px-3" style="font-size:0.75rem;">Gửi</span>
                        `;
                        btn.onclick = () => sendShare(c.conversationId, btn);
                        list.appendChild(btn);
                    });
                });
        }

        function sendShare(convId, btnEl) {
            const msg = document.getElementById('shareMessageContent').value;
            const productId = @Model.Product.ProductId;
            
            const btnSend = btnEl.querySelector('.btn-primary');
            btnSend.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
            btnSend.disabled = true;

            const formData = new FormData();
            formData.append('productId', productId);
            formData.append('conversationId', convId);
            formData.append('messageContent', msg);

            fetch('/Chat/ShareProduct', {
                method: 'POST',
                body: formData
            })
            .then(r => {
                if(r.ok) {
                    btnSend.innerHTML = '<i class="bi bi-check2"></i> Đã gửi';
                    btnSend.classList.replace('btn-primary', 'btn-success');
                    setTimeout(() => {
                        var modal = bootstrap.Modal.getInstance(document.getElementById('shareChatModal'));
                        modal.hide();
                    }, 1000);
                } else {
                    btnSend.innerHTML = 'Lỗi';
                    btnSend.disabled = false;
                }
            })
            .catch(err => {
                btnSend.innerHTML = 'Lỗi';
                btnSend.disabled = false;
            });
        }
    </script>
}

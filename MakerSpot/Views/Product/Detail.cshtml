@model MakerSpot.ViewModels.ProductDetailViewModel

@{
    ViewData["Title"] = Model.Product.ProductName;
}

<div class="row mt-4 mb-5">
    <div class="col-md-8">
        <!-- Main Product Info -->
        <div class="d-flex align-items-center mb-4">
            <img src="@(string.IsNullOrEmpty(Model.Product.LogoUrl) ? "/images/default-logo.png" : Model.Product.LogoUrl)" alt="@Model.Product.ProductName Logo" class="product-logo rounded me-4" style="width: 100px; height: 100px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/100?text=Logo';" />
            <div>
                <h2 class="fw-bold mb-1">@Model.Product.ProductName</h2>
                <h5 class="text-muted fw-normal mb-2">@Model.Product.Tagline</h5>
                <div class="topic-tags">
                    @foreach (var pt in Model.Product.ProductTopics)
                    {
                        <span class="badge bg-light text-secondary border fw-normal me-1">@pt.Topic.TopicName</span>
                    }
                </div>
            </div>
            <div class="ms-auto pb-4">
                <form asp-controller="Product" asp-action="Upvote" method="post">
                    <input type="hidden" name="productId" value="@Model.Product.ProductId" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                    <button type="submit" class="btn btn-lg @(Model.HasUpvoted ? "btn-outline-primary active" : "btn-outline-secondary") btn-upvote px-4 d-flex flex-column align-items-center">
                        <i class="bi bi-caret-up-fill fs-4 lh-1"></i>
                        <span class="fw-bold fw-6">@Model.Product.UpvoteCount</span>
                    </button>
                </form>                
            </div>
        </div>

        <div class="d-flex mb-4 gap-2">
            <a href="@Model.Product.WebsiteUrl" target="_blank" class="btn btn-primary fw-bold text-white px-4">Visit Website <i class="bi bi-box-arrow-up-right ms-1"></i></a>
            @if (!string.IsNullOrEmpty(Model.Product.DemoUrl))
            {
                <a href="@Model.Product.DemoUrl" target="_blank" class="btn btn-outline-secondary fw-bold px-4">Demo</a>
            }
        </div>

        <!-- Media Carousel -->
        @if (Model.Product.ProductMedia.Any())
        {
            <div id="productMediaCarousel" class="carousel slide mb-5" data-bs-ride="carousel">
                <div class="carousel-indicators">
                    @for (int i = 0; i < Model.Product.ProductMedia.Count; i++)
                    {
                        <button type="button" data-bs-target="#productMediaCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")"></button>
                    }
                </div>
                <div class="carousel-inner rounded shadow-sm border">
                    @foreach (var media in Model.Product.ProductMedia.Select((value, i) => new { i, value }))
                    {
                        <div class="carousel-item @(media.i == 0 ? "active" : "")">
                            @if (media.value.MediaType == "Video")
                            {
                                <!-- In a real app, parse Youtube/Vimeo. Here we just show link or placeholder -->
                                <div class="bg-dark text-white d-flex flex-column align-items-center justify-content-center p-5 text-center" style="height: 400px;">
                                    <i class="bi bi-play-circle mb-3 text-white-50" style="font-size: 4rem;"></i>
                                    <h5>Product Video</h5>
                                    <a href="@media.value.MediaUrl" class="text-info" target="_blank">@media.value.MediaUrl</a>
                                </div>
                            }
                            else
                            {
                                <img src="@media.value.MediaUrl" class="d-block w-100" style="max-height: 400px; object-fit: contain; background: #f8f9fa;" alt="Product media @media.i" onerror="this.src='https://via.placeholder.com/800x400?text=No+Image';">
                            }
                        </div>
                    }
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#productMediaCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon bg-dark rounded-circle p-2" aria-hidden="true"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#productMediaCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon bg-dark rounded-circle p-2" aria-hidden="true"></span>
                </button>
            </div>
        }

        <!-- Description -->
        <h5 class="fw-bold mb-3">Giới thiệu sản phẩm</h5>
        <div class="text-muted lh-lg mb-5" style="white-space: pre-wrap;">@Model.Product.Description</div>

        <!-- Comments Section -->
        <hr class="mb-4" />
        <h5 class="fw-bold mb-4">Thảo luận (@Model.Product.CommentCount)</h5>

        <!-- New Comment Form -->
        @if (User.Identity!.IsAuthenticated)
        {
            <div class="card mb-4 border-0 shadow-sm bg-light">
                <div class="card-body p-3">
                    <form asp-controller="Product" asp-action="PostComment" method="post">
                        <input type="hidden" name="productId" value="@Model.Product.ProductId" />
                        <div class="mb-2">
                            <textarea name="content" class="form-control bg-white" rows="3" placeholder="Chia sẻ suy nghĩ của bạn..." required></textarea>
                        </div>
                        <div class="text-end">
                            <button type="submit" class="btn btn-primary btn-sm fw-bold px-4">Gửi bình luận</button>
                        </div>
                    </form>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-secondary py-2 mb-4 text-center">
                Vui lòng <a asp-controller="Auth" asp-action="Login" class="fw-bold text-decoration-none">đăng nhập</a> để bình luận.
            </div>
        }

        <!-- Comments List -->
        <div class="comment-list">
            @if (!Model.Product.Comments.Any())
            {
                <p class="text-muted text-center py-4">Chưa có bình luận nào. Hãy là người đầu tiên thảo luận!</p>
            }
            
            @foreach (var comment in Model.Product.Comments)
            {
                <div class="d-flex mb-4">
                    <img src="@(string.IsNullOrEmpty(comment.User.AvatarUrl) ? "/images/default-avatar.png" : comment.User.AvatarUrl)" alt="User Avatar" class="rounded-circle me-3 border" style="width: 40px; height: 40px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/40?text=U';" />
                    <div class="flex-grow-1">
                        <div class="bg-white border rounded p-3 mb-2 shadow-sm">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div>
                                    <span class="fw-bold text-dark">@comment.User.FullName</span>
                                    <span class="text-muted ms-1 small">@@@comment.User.Username</span>
                                </div>
                                <span class="text-muted small">@comment.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </div>
                            <p class="mb-0 text-dark">@comment.Content</p>
                        </div>

                        <div class="ms-2 mb-3">
                            @if (User.Identity!.IsAuthenticated)
                            {
                                <button type="button" class="btn btn-link text-muted p-0 text-decoration-none small fw-semibold" onclick="document.getElementById('reply-form-@comment.CommentId').classList.toggle('d-none')">Trả lời</button>

                                <div id="reply-form-@comment.CommentId" class="d-none mt-2">
                                    <form asp-controller="Product" asp-action="PostComment" method="post" class="d-flex align-items-start">
                                        <input type="hidden" name="productId" value="@Model.Product.ProductId" />
                                        <input type="hidden" name="parentCommentId" value="@comment.CommentId" />
                                        <textarea name="content" class="form-control form-control-sm me-2" rows="1" placeholder="Viết phản hồi..." required></textarea>
                                        <button type="submit" class="btn btn-primary btn-sm fw-bold">Gửi</button>
                                    </form>
                                </div>
                            }
                        </div>

                        <!-- Replies -->
                        @if (comment.Replies.Any())
                        {
                            <div class="replies ms-4 mt-2 border-start ps-3 border-2 border-light">
                                @foreach (var reply in comment.Replies)
                                {
                                    <div class="d-flex mb-3">
                                        <img src="@(string.IsNullOrEmpty(reply.User.AvatarUrl) ? "/images/default-avatar.png" : reply.User.AvatarUrl)" alt="User Avatar" class="rounded-circle me-2 border" style="width: 32px; height: 32px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/32?text=U';" />
                                        <div class="flex-grow-1">
                                            <div class="bg-light rounded p-2 px-3">
                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                    <div>
                                                        <span class="fw-bold text-dark small">@reply.User.FullName</span>
                                                    </div>
                                                </div>
                                                <p class="mb-0 text-dark small">@reply.Content</p>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Right Sidebar -->
    <div class="col-md-4 pl-md-4">
        <!-- Makers Widget -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3 text-uppercase text-muted" style="letter-spacing: 0.5px; font-size: 0.85rem;">Makers</h6>
                
                @foreach (var pm in Model.Product.ProductMakers)
                {
                    <div class="d-flex align-items-center mb-3">
                        <img src="@(string.IsNullOrEmpty(pm.User.AvatarUrl) ? "/images/default-avatar.png" : pm.User.AvatarUrl)" alt="Maker Avatar" class="rounded-circle me-3 border" style="width: 48px; height: 48px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/48?text=M';" />
                        <div>
                            <div class="fw-bold text-dark">@pm.User.FullName</div>
                            <div class="text-muted small">@pm.MakerRole</div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Launch Info Widget -->
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3 text-uppercase text-muted" style="letter-spacing: 0.5px; font-size: 0.85rem;">Thông tin</h6>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Ngày ra mắt</span>
                    <span class="fw-semibold">@(Model.Product.LaunchDate?.ToString("dd/MM/yyyy") ?? "N/A")</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Lượt xem</span>
                    <span class="fw-semibold">@Model.Product.ViewCount</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Trạng thái</span>
                    <span class="badge bg-success">@Model.Product.Status</span>
                </div>
            </div>
        </div>

        <!-- Add to Collection Widget -->
        @if (User.Identity!.IsAuthenticated && Model.UserCollections.Any())
        {
            <div class="card border-0 shadow-sm mt-4">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3 text-uppercase text-muted" style="letter-spacing: 0.5px; font-size: 0.85rem;"><i class="bi bi-collection me-1"></i>Lưu vào Collection</h6>
                    <form asp-controller="Collection" asp-action="AddItem" method="post">
                        <input type="hidden" name="productId" value="@Model.Product.ProductId" />
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                        <div class="input-group">
                            <select name="collectionId" class="form-select form-select-sm">
                                @foreach (var col in Model.UserCollections)
                                {
                                    <option value="@col.CollectionId">@col.CollectionName</option>
                                }
                            </select>
                            <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> Thêm</button>
                        </div>
                    </form>
                </div>
            </div>
        }
        else if (User.Identity.IsAuthenticated)
        {
            <div class="card border-0 shadow-sm mt-4">
                <div class="card-body p-4 text-center">
                    <p class="text-muted small mb-2">Bạn chưa có collection nào.</p>
                    <a asp-controller="Collection" asp-action="Create" class="btn btn-outline-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Tạo Collection</a>
                </div>
            </div>
        }
    </div>
</div>

@model MakerSpot.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Trang chủ";
    var topicName = Model.Topics.FirstOrDefault(t => t.Slug == Model.SelectedTopicSlug)?.TopicName;
}

<div class="row g-4">
    <!-- ===== MAIN FEED ===== -->
    <div class="col-lg-8">

        <!-- Header row -->
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h1 class="h4 fw-bold mb-0">
                    @if (!string.IsNullOrEmpty(Model.SearchQuery))
                    {
                        <text>Kết quả: "@Model.SearchQuery"</text>
                    }
                    else if (!string.IsNullOrEmpty(Model.SelectedTopicSlug))
                    {
                        <text>Chủ đề: @topicName</text>
                    }
                    else if (Model.SortBy == "newest")
                    {
                        <text>Sản phẩm mới nhất</text>
                    }
                    else
                    {
                        <text>Trending hôm nay 🔥</text>
                    }
                </h1>
                @if (!string.IsNullOrEmpty(Model.SelectedTopicSlug) || !string.IsNullOrEmpty(Model.SearchQuery))
                {
                    <a asp-action="Index" class="text-muted small text-decoration-none">
                        <i class="bi bi-x-circle me-1"></i>Xóa bộ lọc
                    </a>
                }
            </div>
            <!-- Sort tabs -->
            <div class="d-flex gap-1 bg-white border rounded-pill p-1" style="border-color:#e5e7eb!important;">
                <a asp-action="Index" asp-route-sort="trending" asp-route-search="@Model.SearchQuery" asp-route-topic="@Model.SelectedTopicSlug"
                   class="btn btn-sm rounded-pill px-3 fw-semibold @(Model.SortBy != "newest" ? "btn-primary" : "text-muted")" style="font-size:.8rem;">
                    🔥 Trending
                </a>
                <a asp-action="Index" asp-route-sort="newest" asp-route-search="@Model.SearchQuery" asp-route-topic="@Model.SelectedTopicSlug"
                   class="btn btn-sm rounded-pill px-3 fw-semibold @(Model.SortBy == "newest" ? "btn-primary" : "text-muted")" style="font-size:.8rem;">
                    ✨ Mới nhất
                </a>
            </div>
        </div>

        <!-- Product list -->
        @if (!Model.Products.Any())
        {
            <div class="card border-0 empty-state text-center py-5 fade-in">
                <i class="bi bi-inbox d-block mx-auto" style="font-size:3.5rem;color:#d1d5db;"></i>
                <h5 class="mt-3 text-dark">Không có sản phẩm nào</h5>
                <p class="text-muted">
                    @if (!string.IsNullOrEmpty(Model.SearchQuery))
                    {
                        <text>Không tìm thấy kết quả cho "@Model.SearchQuery".</text>
                    }
                    else
                    {
                        <text>Chưa có sản phẩm nào được phê duyệt.</text>
                    }
                </p>
                @if (User.Identity!.IsAuthenticated)
                {
                    <a asp-controller="Product" asp-action="Submit" class="btn btn-primary mt-2 mx-auto" style="width:fit-content;">
                        <i class="bi bi-plus me-1"></i>Gửi sản phẩm đầu tiên
                    </a>
                }
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-2 fade-in">
                @foreach (var product in Model.Products)
                {
                    <div class="card product-card border-0">
                        <div class="card-body p-3 p-md-4 d-flex align-items-center gap-3">
                            <!-- Logo -->
                            <a asp-controller="Product" asp-action="Detail" asp-route-id="@product.ProductId" class="flex-shrink-0">
                                <img src="@(string.IsNullOrEmpty(product.LogoUrl) ? "/images/default-logo.png" : product.LogoUrl)"
                                     alt="@product.ProductName"
                                     class="product-logo"
                                     style="width:60px;height:60px;"
                                     onerror="this.src='https://placehold.co/60x60/f3f4f6/9ca3af?text=🚀';" />
                            </a>
                            <!-- Info -->
                            <div class="flex-grow-1 min-w-0 hover-title">
                                <a asp-controller="Product" asp-action="Detail" asp-route-id="@product.ProductId"
                                   class="text-decoration-none">
                                    <h5 class="mb-0 fw-bold" style="font-size:1rem;color:#1f2937;">@product.ProductName</h5>
                                    <p class="text-muted mb-2 mt-1" style="font-size:.88rem;line-height:1.4;">@product.Tagline</p>
                                </a>
                                <div class="d-flex flex-wrap gap-1 align-items-center">
                                    @foreach (var pt in product.ProductTopics)
                                    {
                                        <a asp-action="Index" asp-route-topic="@pt.Topic.Slug" asp-route-sort="@Model.SortBy"
                                           class="topic-badge">@pt.Topic.TopicName</a>
                                    }
                                </div>
                            </div>
                            <!-- Actions -->
                            <div class="d-flex flex-column align-items-center gap-2 flex-shrink-0">
                                <form asp-controller="Product" asp-action="Upvote" method="post">
                                    <input type="hidden" name="productId" value="@product.ProductId" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                    <button type="submit" class="btn-upvote btn d-flex flex-column align-items-center">
                                        <i class="bi bi-caret-up-fill"></i>
                                        <span>@product.UpvoteCount</span>
                                    </button>
                                </form>
                                <a asp-controller="Product" asp-action="Detail" asp-route-id="@product.ProductId"
                                   class="text-decoration-none d-flex align-items-center gap-1" style="color:var(--ph-muted);font-size:.82rem;font-weight:600;">
                                    <i class="bi bi-chat"></i> @product.CommentCount
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- ===== SIDEBAR ===== -->
    <div class="col-lg-4">
        <div class="sidebar-sticky d-flex flex-column gap-3">
            <!-- Topics -->
            <div class="card border-0">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold mb-0 text-uppercase" style="font-size:.75rem;letter-spacing:.8px;color:var(--ph-muted);">
                            Chủ đề
                        </h6>
                        @if (!string.IsNullOrEmpty(Model.SelectedTopicSlug))
                        {
                            <a asp-action="Index" asp-route-sort="@Model.SortBy" asp-route-search="@Model.SearchQuery"
                               class="text-muted text-decoration-none" style="font-size:.8rem;">Xóa lọc</a>
                        }
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var topic in Model.Topics)
                        {
                            <a asp-action="Index" asp-route-topic="@topic.Slug" asp-route-sort="@Model.SortBy" asp-route-search="@Model.SearchQuery"
                               class="topic-badge @(Model.SelectedTopicSlug == topic.Slug ? "active" : "")">
                                @topic.TopicName
                            </a>
                        }
                    </div>
                </div>
            </div>

            <!-- CTA for guests -->
            @if (!User.Identity!.IsAuthenticated)
            {
                <div class="card border-0" style="background:linear-gradient(135deg,#fff5f4,#fff);">
                    <div class="card-body p-4 text-center">
                        <div class="mb-2" style="font-size:2rem;">🚀</div>
                        <h6 class="fw-bold mb-2">Bạn có sản phẩm mới?</h6>
                        <p class="text-muted mb-3" style="font-size:.875rem;">Chia sẻ với cộng đồng MakerSpot ngay hôm nay.</p>
                        <a asp-controller="Auth" asp-action="Register" class="btn btn-primary fw-semibold w-100">Đăng ký miễn phí</a>
                        <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-secondary fw-semibold w-100 mt-2">Đăng nhập</a>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0">
                    <div class="card-body p-4 text-center">
                        <p class="text-muted mb-2" style="font-size:.875rem;">Bạn có sản phẩm muốn chia sẻ?</p>
                        <a asp-controller="Product" asp-action="Submit" class="btn btn-primary fw-semibold w-100">
                            <i class="bi bi-plus-lg me-1"></i>Gửi sản phẩm
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

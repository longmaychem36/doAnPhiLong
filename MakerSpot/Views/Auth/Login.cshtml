@model MakerSpot.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="row justify-content-center" style="margin-top:4rem;">
    <div class="col-md-5 col-lg-4">
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center rounded-3 mx-auto mb-3"
                 style="width:48px;height:48px;background:var(--ph-orange);">
                <span class="text-white fw-bold" style="font-size:1.4rem;">P</span>
            </div>
            <h1 class="h3 fw-bold mb-1">Chào mừng trở lại</h1>
            <p class="text-muted" style="font-size:.9rem;">Đăng nhập vào tài khoản MakerSpot của bạn</p>
        </div>

        <div class="card border-0">
            <div class="card-body p-4">
                <form asp-action="Login" method="post">
                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(""))
                    {
                        <div class="alert d-flex align-items-center gap-2 mb-3 p-3"
                             style="background:#fef2f2;border-left:3px solid #dc2626;border-radius:8px;">
                            <i class="bi bi-exclamation-circle-fill" style="color:#dc2626;"></i>
                            <div asp-validation-summary="ModelOnly" class="mb-0" style="color:#dc2626;font-size:.875rem;"></div>
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label">Tên đăng nhập</label>
                        <input asp-for="Username" class="form-control" placeholder="Nhập username..." autofocus />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label">Mật khẩu</label>
                        <input asp-for="Password" class="form-control" placeholder="Nhập mật khẩu..." />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 fw-semibold py-2">Đăng nhập</button>
                </form>
            </div>
        </div>

        <p class="text-center mt-3 text-muted" style="font-size:.875rem;">
            Chưa có tài khoản?
            <a asp-action="Register" class="fw-semibold text-decoration-none" style="color:var(--ph-orange);">Đăng ký miễn phí</a>
        </p>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

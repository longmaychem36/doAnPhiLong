@{
    ViewData["Title"] = "Từ chối truy cập";
}

<div class="row align-items-center justify-content-center min-vh-50 py-5 my-5 text-center">
    <div class="col-md-6 fade-in">
        <i class="bi bi-shield-lock text-danger mb-4" style="font-size: 5rem;"></i>
        <h1 class="display-5 fw-bold text-dark mb-3">Truy cập bị từ chối</h1>
        <h3 class="fw-semibold text-secondary mb-4">403 Forbidden</h3>
        <p class="text-muted mb-4 fs-5">Xin lỗi, bạn không có quyền truy cập vào nội dung hoặc tính năng này.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-danger btn-lg rounded-pill px-5 shadow-sm">
            <i class="bi bi-arrow-left-circle me-2"></i>Trở về
        </a>
    </div>
</div>

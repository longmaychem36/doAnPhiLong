@model List<MakerSpot.Models.ForumPost>
@{
    ViewData["Title"] = "Diễn đàn thảo luận";
    var selectedTag = ViewData["SelectedTag"] as string;
    var searchQuery = ViewData["SearchQuery"] as string;
    int currentPage = ViewData["CurrentPage"] != null ? (int)ViewData["CurrentPage"] : 1;
    int totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
    var tags = new[] { "Hỏi đáp", "Chia sẻ", "Thảo luận", "Tuyển dụng", "Góp ý" };
}

<div class="row g-4">
    <!-- Main Content -->
    <div class="col-lg-8">
        <!-- Header -->
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h1 class="h4 fw-bold mb-1">
                    <i class="bi bi-chat-square-text me-2" style="color:#ff6154;"></i>Diễn đàn
                </h1>
                <p class="text-muted mb-0" style="font-size:.85rem;">Nơi cộng đồng trao đổi, chia sẻ kiến thức và ý tưởng</p>
            </div>
            @if (User.Identity!.IsAuthenticated)
            {
                <a asp-action="Create" class="btn btn-primary fw-semibold px-4" style="border-radius:10px;">
                    <i class="bi bi-plus-lg me-1"></i>Tạo bài viết
                </a>
            }
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Tags Filter -->
        <div class="d-flex flex-wrap gap-2 mb-4">
            <a asp-action="Index" class="btn btn-sm rounded-pill px-3 fw-semibold @(string.IsNullOrEmpty(selectedTag) ? "btn-dark" : "btn-outline-secondary")" style="font-size:.8rem;">
                Tất cả
            </a>
            @foreach (var t in tags)
            {
                <a asp-action="Index" asp-route-tag="@t" class="btn btn-sm rounded-pill px-3 fw-semibold @(selectedTag == t ? "btn-dark" : "btn-outline-secondary")" style="font-size:.8rem;">
                    @t
                </a>
            }
        </div>

        <!-- Post List -->
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-chat-square d-block mb-3" style="font-size:3rem; color:#d1d5db;"></i>
                <h5 class="text-muted fw-semibold">Chưa có bài viết nào</h5>
                <p class="text-muted small">Hãy là người đầu tiên tạo bài thảo luận!</p>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                @foreach (var post in Model)
                {
                    <div class="card border-0 shadow-sm" style="border-radius:12px; transition: transform .15s, box-shadow .15s;">
                        <div class="card-body p-3">
                            <div class="d-flex gap-3">
                                <!-- Avatar -->
                                <div class="flex-shrink-0">
                                    @if (!string.IsNullOrEmpty(post.User.AvatarUrl))
                                    {
                                        <img src="@post.User.AvatarUrl" class="rounded-circle" style="width:40px;height:40px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="avatar" style="width:40px;height:40px;font-size:.85rem;">@post.User.Username.Substring(0,1).ToUpper()</div>
                                    }
                                </div>
                                <!-- Content -->
                                <div class="flex-grow-1 min-w-0">
                                    <div class="d-flex align-items-start justify-content-between">
                                        <div class="min-w-0">
                                            <a asp-action="Detail" asp-route-id="@post.ForumPostId" class="fw-bold text-dark text-decoration-none d-block text-truncate" style="font-size:1rem;">
                                                @if (post.IsPinned)
                                                {
                                                    <i class="bi bi-pin-angle-fill text-danger me-1" style="font-size:.8rem;"></i>
                                                }
                                                @post.Title
                                            </a>
                                            <div class="d-flex align-items-center gap-2 mt-1 flex-wrap">
                                                <a asp-controller="User" asp-action="Profile" asp-route-username="@post.User.Username" class="text-muted text-decoration-none fw-semibold" style="font-size:.78rem;">
                                                    @@@post.User.Username
                                                </a>
                                                <span class="text-muted" style="font-size:.75rem;">•</span>
                                                <span class="text-muted" style="font-size:.75rem;">@post.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                                @if (!string.IsNullOrEmpty(post.Tag))
                                                {
                                                    <span class="text-muted" style="font-size:.75rem;">•</span>
                                                    <a asp-action="Index" asp-route-tag="@post.Tag" class="badge rounded-pill text-decoration-none" style="background:#f3f4f6; color:#6b7280; font-size:.7rem;">@post.Tag</a>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Preview -->
                                    <p class="text-muted mb-0 mt-2 text-truncate" style="font-size:.85rem; max-width:100%;">
                                        @(post.Content.Length > 150 ? post.Content.Substring(0, 150) + "..." : post.Content)
                                    </p>

                                    <!-- Stats -->
                                    <div class="d-flex align-items-center gap-3 mt-2">
                                        <span class="text-muted d-flex align-items-center gap-1" style="font-size:.78rem;">
                                            <i class="bi bi-chat-left-text"></i> @post.Replies.Count trả lời
                                        </span>
                                        <span class="text-muted d-flex align-items-center gap-1" style="font-size:.78rem;">
                                            <i class="bi bi-eye"></i> @post.ViewCount lượt xem
                                        </span>
                                        @if (post.IsLocked)
                                        {
                                            <span class="text-warning d-flex align-items-center gap-1" style="font-size:.78rem;">
                                                <i class="bi bi-lock-fill"></i> Đã khóa
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Pagination -->
        @if (totalPages > 1)
        {
            <nav class="mt-4 d-flex justify-content-center">
                <ul class="pagination pagination-sm gap-1">
                    @if (currentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link rounded-pill px-3 fw-semibold" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-tag="@selectedTag" asp-route-search="@searchQuery">
                                <i class="bi bi-chevron-left me-1"></i>Trước
                            </a>
                        </li>
                    }
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link rounded-pill px-3" asp-action="Index" asp-route-page="@i" asp-route-tag="@selectedTag" asp-route-search="@searchQuery">@i</a>
                        </li>
                    }
                    @if (currentPage < totalPages)
                    {
                        <li class="page-item">
                            <a class="page-link rounded-pill px-3 fw-semibold" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-tag="@selectedTag" asp-route-search="@searchQuery">
                                Tiếp<i class="bi bi-chevron-right ms-1"></i>
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
        <!-- Search -->
        <div class="card border-0 shadow-sm mb-4" style="border-radius:12px;">
            <div class="card-body p-3">
                <h6 class="fw-bold mb-3" style="font-size:.8rem; text-transform:uppercase; letter-spacing:.5px; color:#9ca3af;">
                    <i class="bi bi-search me-1"></i>Tìm kiếm
                </h6>
                <form asp-action="Index" method="get">
                    <div class="input-group">
                        <input type="text" name="search" class="form-control" placeholder="Tìm bài viết..." value="@searchQuery"
                               style="border-radius:8px 0 0 8px; border-color:#e5e7eb;" />
                        <button type="submit" class="btn btn-primary" style="border-radius:0 8px 8px 0;">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Forum Stats -->
        <div class="card border-0 shadow-sm mb-4" style="border-radius:12px;">
            <div class="card-body p-3">
                <h6 class="fw-bold mb-3" style="font-size:.8rem; text-transform:uppercase; letter-spacing:.5px; color:#9ca3af;">
                    <i class="bi bi-bar-chart me-1"></i>Thống kê
                </h6>
                <div class="d-flex justify-content-around text-center">
                    <div>
                        <div class="fw-bold" style="font-size:1.3rem; color:#ff6154;">@ViewBag.TotalPosts</div>
                        <div class="text-muted" style="font-size:.75rem;">Bài viết</div>
                    </div>
                    <div>
                        <div class="fw-bold" style="font-size:1.3rem; color:#ff6154;">@ViewBag.TotalReplies</div>
                        <div class="text-muted" style="font-size:.75rem;">Trả lời</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Rules -->
        <div class="card border-0 shadow-sm" style="border-radius:12px;">
            <div class="card-body p-3">
                <h6 class="fw-bold mb-3" style="font-size:.8rem; text-transform:uppercase; letter-spacing:.5px; color:#9ca3af;">
                    <i class="bi bi-shield-check me-1"></i>Nội quy diễn đàn
                </h6>
                <ul class="list-unstyled mb-0" style="font-size:.82rem; color:#4b5563;">
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Tôn trọng mọi người</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Không spam hoặc quảng cáo</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Đặt tiêu đề rõ ràng</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Sử dụng tag phù hợp</li>
                    <li><i class="bi bi-check-circle text-success me-2"></i>Chia sẻ kiến thức, giúp đỡ cộng đồng</li>
                </ul>
            </div>
        </div>
    </div>
</div>

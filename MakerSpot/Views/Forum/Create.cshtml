@{
    ViewData["Title"] = "Tạo bài viết mới";
    var tags = new[] { "Hỏi đáp", "Chia sẻ", "Thảo luận", "Tuyển dụng", "Góp ý" };
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb" style="font-size:.82rem;">
                <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Diễn đàn</a></li>
                <li class="breadcrumb-item active">Tạo bài viết</li>
            </ol>
        </nav>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert">
                <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card border-0 shadow-sm" style="border-radius:14px;">
            <div class="card-body p-4">
                <h4 class="fw-bold mb-4">
                    <i class="bi bi-pencil-square me-2" style="color:#ff6154;"></i>Tạo bài viết mới
                </h4>

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold" style="font-size:.85rem;">Tiêu đề <span class="text-danger">*</span></label>
                        <input type="text" name="title" class="form-control" placeholder="VD: Làm sao để tăng lượt upvote cho sản phẩm?"
                               required maxlength="200" style="border-radius:10px; border-color:#e5e7eb;" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold" style="font-size:.85rem;">Nhãn (Tag)</label>
                        <select name="tag" class="form-select" style="border-radius:10px; border-color:#e5e7eb;">
                            <option value="">-- Chọn nhãn --</option>
                            @foreach (var t in tags)
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold" style="font-size:.85rem;">Nội dung <span class="text-danger">*</span></label>
                        <textarea name="content" class="form-control" rows="10"
                                  placeholder="Viết nội dung bài thảo luận của bạn ở đây..."
                                  required style="border-radius:10px; border-color:#e5e7eb;"></textarea>
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="btn btn-light fw-semibold px-4" style="border-radius:10px;">
                            <i class="bi bi-arrow-left me-1"></i>Quay lại
                        </a>
                        <button type="submit" class="btn btn-primary fw-semibold px-4" style="border-radius:10px;">
                            <i class="bi bi-send me-1"></i>Đăng bài
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="MakerSpot - Khám phá và chia sẻ sản phẩm công nghệ thú vị" />
    <title>@ViewData["Title"] - MakerSpot</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-lg sticky-top">
            <div class="container">
                <!-- Brand -->
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-2 text-white fw-bold" style="width:32px;height:32px;background:var(--ph-orange);font-size:1rem;">P</div>
                    MakerSpot
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navMain">
                    <!-- Left links -->
                    <ul class="navbar-nav me-auto align-items-lg-center gap-1 ms-3">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Sản phẩm</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index" asp-route-sort="newest">Mới nhất</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Forum" asp-action="Index">
                                <i class="bi bi-chat-square-text me-1"></i>Diễn đàn
                            </a>
                        </li>
                    </ul>

                    <!-- Search -->
                    <form asp-controller="Home" asp-action="Index" method="get" class="d-flex mx-auto" style="width:100%;max-width:340px;">
                        <div class="input-group">
                            <span class="input-group-text border-end-0 bg-white border" style="border-radius:8px 0 0 8px; border-color:#e5e7eb;">
                                <i class="bi bi-search text-muted" style="font-size:.85rem;"></i>
                            </span>
                            <input type="search" name="search" class="form-control border-start-0 ps-1"
                                   placeholder="Tìm kiếm sản phẩm..." value="@Context.Request.Query["search"]"
                                   style="border-radius:0 8px 8px 0; border-color:#e5e7eb;">
                        </div>
                    </form>

                    <!-- Right actions -->
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-2">
                        @if (User.Identity!.IsAuthenticated)
                        {
                            @if (User.IsInRole("Admin") || User.IsInRole("Moderator"))
                            {
                                <li class="nav-item">
                                    <a class="btn btn-sm fw-semibold text-white px-3" style="background:#1f2937;border-radius:8px;"
                                       asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                        <i class="bi bi-shield-check me-1"></i>@(User.IsInRole("Admin") ? "Admin" : "Moderator")
                                    </a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link position-relative" asp-controller="Notification" asp-action="Index" title="Thông báo">
                                    <i class="bi bi-bell" style="font-size:1.1rem;"></i>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Chat" asp-action="Index" title="Tin nhắn">
                                    <i class="bi bi-chat-dots" style="font-size:1.1rem;"></i>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Collection" asp-action="MyCollections" title="Collections">
                                    <i class="bi bi-bookmark" style="font-size:1.1rem;"></i>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary fw-semibold px-4 py-2" style="font-size:.875rem;"
                                   asp-controller="Product" asp-action="Submit">
                                    <i class="bi bi-plus me-1 fw-bold" style="font-size:1rem;"></i>Gửi sản phẩm
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a href="#" class="btn btn-sm border d-flex align-items-center gap-2 text-decoration-none"
                                   style="border-radius:20px;border-color:#e5e7eb;padding:0.3rem 0.8rem 0.3rem 0.3rem;"
                                   data-bs-toggle="dropdown">
                                    <div class="avatar" style="width:28px;height:28px;font-size:0.8rem;">@User.Identity.Name.Substring(0,1).ToUpper()</div>
                                    <span class="fw-semibold" style="font-size:.85rem;color:#374151;">@User.Identity.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg mt-1" style="border-radius:12px;min-width:200px;">
                                    <li class="px-3 py-2">
                                        <p class="mb-0 fw-bold text-dark" style="font-size:.9rem;">@User.Identity.Name</p>
                                    </li>
                                    <li><hr class="dropdown-divider my-1"></li>
                                    <li>
                                        <a class="dropdown-item py-2" asp-controller="User" asp-action="Profile" asp-route-username="@User.Identity.Name">
                                            <i class="bi bi-person me-2 text-muted"></i>Hồ sơ cá nhân
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2" asp-controller="Collection" asp-action="MyCollections">
                                            <i class="bi bi-bookmark me-2 text-muted"></i>Collections
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider my-1"></li>
                                    <li>
                                        <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0 p-0">
                                            <button type="submit" class="dropdown-item py-2 text-danger bg-transparent" style="border:none;">
                                                <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-semibold" asp-controller="Auth" asp-action="Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary fw-semibold px-4 py-2" style="font-size:.875rem;" asp-controller="Auth" asp-action="Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- FLASH MESSAGES -->
    <div class="container mt-3">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert d-flex align-items-center gap-2 toast-alert alert-success alert-dismissible fade show" role="alert" style="background:#f0fdf4;border-left:4px solid #16a34a;color:#15803d;">
                <i class="bi bi-check-circle-fill flex-shrink-0"></i>
                <div>@TempData["SuccessMessage"]</div>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert d-flex align-items-center gap-2 toast-alert alert-danger alert-dismissible fade show" role="alert" style="background:#fef2f2;border-left:4px solid #dc2626;color:#dc2626;">
                <i class="bi bi-exclamation-circle-fill flex-shrink-0"></i>
                <div>@TempData["ErrorMessage"]</div>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
    </div>

    <!-- MAIN CONTENT -->
    <main>
        <div class="container py-4">
            @RenderBody()
        </div>
    </main>

    <!-- FOOTER -->
    <footer class="site-footer">
        <div class="container d-flex flex-wrap justify-content-between align-items-center gap-3">
            <span class="fw-bold" style="color:var(--ph-orange);">MakerSpot</span>
            <span>&copy; @DateTime.Now.Year • Đồ án demo</span>
            <div class="d-flex gap-3">
                <a class="text-muted text-decoration-none" asp-controller="Home" asp-action="Index">Trang chủ</a>
                <a class="text-muted text-decoration-none" asp-controller="Auth" asp-action="Login">Đăng nhập</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Prevent double form submission globally
        $('form').on('submit', function () {
            if ($(this).data('submitted') === true) {
                return false;
            } else {
                $(this).data('submitted', true);
                var btn = $(this).find('button[type="submit"]');
                btn.prop('disabled', true);
                btn.css('opacity', '0.7');
                return true;
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>


@model ErrorViewModel
@{
    ViewData["Title"] = "Đã xảy ra lỗi";
}

<div class="row align-items-center justify-content-center min-vh-50 py-5 my-5 text-center">
    <div class="col-md-7 fade-in">
        <i class="bi bi-exclamation-triangle-fill text-warning mb-4" style="font-size: 5rem;"></i>
        <h1 class="display-4 fw-bold text-dark mb-4">Oops! Đã xảy ra lỗi.</h1>
        <h4 class="fw-normal text-secondary mb-4">Chúng tôi đang xử lý sự cố này. Vui lòng thử lại sau.</h4>
        
        @if (Model.ShowRequestId)
        {
            <div class="bg-light rounded p-3 mb-4 d-inline-block text-start px-4 border shadow-sm">
                <p class="mb-0 text-muted"><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
            </div>
        }
        <div>
            <a href="javascript:history.back()" class="btn btn-outline-secondary btn-lg rounded-pill px-4 me-3 shadow-sm">
                <i class="bi bi-arrow-left me-2"></i>Quay lại
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm">
                <i class="bi bi-house-door me-2"></i>Trang chủ
            </a>
        </div>
    </div>
</div>

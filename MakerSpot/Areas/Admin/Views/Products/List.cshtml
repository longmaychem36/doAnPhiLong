@model IEnumerable<MakerSpot.Models.Product>

@{
    string title = ViewData["Title"]?.ToString() ?? "Danh sách sản phẩm";
}

<!-- Header -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <span class="text-muted" style="font-size:.875rem;">@Model.Count() sản phẩm trong danh sách</span>
</div>

<div class="card border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4" style="width:40%;">Sản phẩm</th>
                        <th>Người đăng</th>
                        <th>Ngày tạo</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="bi bi-inbox d-block mb-2" style="font-size:2.5rem;color:#d1d5db;"></i>
                                <span class="text-muted">Không có sản phẩm nào.</span>
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@(string.IsNullOrEmpty(item.LogoUrl) ? "/images/default-logo.png" : item.LogoUrl)"
                                         class="rounded border flex-shrink-0"
                                         style="width:42px;height:42px;object-fit:cover;"
                                         onerror="this.src='https://placehold.co/42';">
                                    <div class="min-w-0">
                                        <div class="fw-semibold" style="font-size:.9rem;">@item.ProductName</div>
                                        <div class="text-muted small text-truncate" style="max-width:240px;">@item.Tagline</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <a asp-area="" asp-controller="User" asp-action="Profile" asp-route-username="@item.User.Username" target="_blank"
                                   class="text-decoration-none" style="font-size:.875rem;color:#374151;">@@@item.User.Username</a>
                            </td>
                            <td>
                                <div style="font-size:.875rem;">@item.CreatedAt.ToString("dd/MM/yyyy")</div>
                                <div class="text-muted" style="font-size:.78rem;">@item.CreatedAt.ToString("HH:mm")</div>
                            </td>
                            <td>
                                @switch (item.Status)
                                {
                                    case "Approved":
                                        <span class="status-badge status-approved">✓ Approved</span>
                                        break;
                                    case "Pending":
                                        <span class="status-badge status-pending">⏳ Pending</span>
                                        break;
                                    case "Rejected":
                                        <span class="status-badge status-rejected">✗ Rejected</span>
                                        break;
                                    case "Hidden":
                                        <span class="status-badge status-hidden">⊘ Hidden</span>
                                        break;
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a asp-action="Detail" asp-route-id="@item.ProductId"
                                       class="btn btn-sm border fw-semibold" style="font-size:.8rem;background:#fff;">Xem</a>
                                    <button type="button" class="btn btn-sm border border-start-0 dropdown-toggle"
                                            style="background:#fff;" data-bs-toggle="dropdown">
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg" style="border-radius:10px;min-width:180px;">
                                        <li><h6 class="dropdown-header text-muted" style="font-size:.75rem;">Đổi trạng thái</h6></li>
                                        @if (item.Status != "Approved")
                                        {
                                            <li>
                                                <form asp-action="UpdateStatus" method="post">
                                                    <input type="hidden" name="id" value="@item.ProductId" />
                                                    <input type="hidden" name="status" value="Approved" />
                                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                                    <button type="submit" class="dropdown-item py-2" style="color:#15803d;font-size:.875rem;">
                                                        <i class="bi bi-check-circle me-2"></i>Duyệt (Approve)
                                                    </button>
                                                </form>
                                            </li>
                                        }
                                        @if (item.Status != "Pending")
                                        {
                                            <li>
                                                <form asp-action="UpdateStatus" method="post">
                                                    <input type="hidden" name="id" value="@item.ProductId" />
                                                    <input type="hidden" name="status" value="Pending" />
                                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                                    <button type="submit" class="dropdown-item py-2" style="color:#a16207;font-size:.875rem;">
                                                        <i class="bi bi-hourglass-split me-2"></i>Về Pending
                                                    </button>
                                                </form>
                                            </li>
                                        }
                                        @if (item.Status != "Rejected")
                                        {
                                            <li>
                                                <form asp-action="UpdateStatus" method="post">
                                                    <input type="hidden" name="id" value="@item.ProductId" />
                                                    <input type="hidden" name="status" value="Rejected" />
                                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                                    <button type="submit" class="dropdown-item py-2" style="color:#dc2626;font-size:.875rem;">
                                                        <i class="bi bi-x-circle me-2"></i>Từ chối
                                                    </button>
                                                </form>
                                            </li>
                                        }
                                        @if (item.Status != "Hidden")
                                        {
                                            <li>
                                                <form asp-action="UpdateStatus" method="post">
                                                    <input type="hidden" name="id" value="@item.ProductId" />
                                                    <input type="hidden" name="status" value="Hidden" />
                                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                                    <button type="submit" class="dropdown-item py-2" style="color:#6b7280;font-size:.875rem;">
                                                        <i class="bi bi-eye-slash me-2"></i>Ẩn (Hide)
                                                    </button>
                                                </form>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@{
    int currentPage = ViewData["CurrentPage"] != null ? (int)ViewData["CurrentPage"] : 1;
    int totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
}

@if (totalPages > 1)
{
    <nav class="mt-4 d-flex justify-content-center">
        <ul class="pagination pagination-sm gap-1">
            @if (currentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link rounded-pill px-3 fw-semibold" asp-action="Index" asp-route-page="@(currentPage - 1)">
                        <i class="bi bi-chevron-left me-1"></i>Trước
                    </a>
                </li>
            }
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link rounded-pill px-3 fw-semibold" asp-action="Index" asp-route-page="@i">@i</a>
                </li>
            }
            @if (currentPage < totalPages)
            {
                <li class="page-item">
                    <a class="page-link rounded-pill px-3 fw-semibold" asp-action="Index" asp-route-page="@(currentPage + 1)">
                        Sau<i class="bi bi-chevron-right ms-1"></i>
                    </a>
                </li>
            }
        </ul>
    </nav>
}

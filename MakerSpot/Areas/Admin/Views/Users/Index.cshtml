@model IEnumerable<MakerSpot.Models.User>

@{
    ViewData["Title"] = "Quản lý Users";
}

                    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <h1 class="h3 fw-bold mb-0"><i class="bi bi-people me-2"></i>Quản lý Users</h1>
    <div>
        <span class="badge bg-primary fs-6 me-2">@Model.Count() users</span>
        <a asp-action="CreateModerator" class="btn btn-outline-primary fw-semibold"><i class="bi bi-person-plus me-1"></i>Tạo Moderator</a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>Roles</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="fw-bold text-muted">#@user.UserId</td>
                        <td>
                            <a asp-area="" asp-controller="User" asp-action="Profile" asp-route-username="@user.Username" target="_blank" class="text-decoration-none fw-bold">
                                @@@user.Username
                            </a>
                        </td>
                        <td>@user.FullName</td>
                        <td class="text-muted">@user.Email</td>
                        <td>
                            @foreach (var ur in user.UserRoles)
                            {
                                var badgeClass = ur.Role.RoleName switch
                                {
                                    "Admin" => "bg-danger",
                                    "Moderator" => "bg-warning text-dark",
                                    _ => "bg-secondary"
                                };
                                <span class="badge @badgeClass me-1">@ur.Role.RoleName</span>
                            }
                        </td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Inactive</span>
                            }
                        </td>
                        <td class="text-muted small">@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (user.Username != "admin" && user.Username != User.Identity.Name)
                            {
                                <form asp-action="ToggleLock" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@user.UserId" />
                                    <button type="submit" class="btn btn-sm @(user.IsActive ? "btn-outline-danger" : "btn-outline-success")" onclick="return confirm('Bạn có chắc chắn muốn thay đổi trạng thái tài khoản này?');">
                                        @if(user.IsActive){ <text><i class="bi bi-lock me-1"></i>Khóa</text> }
                                        else { <text><i class="bi bi-unlock me-1"></i>Mở khóa</text> }
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@model MakerSpot.ViewModels.Admin.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard Thống kê";
}

<!-- Cấp 1: Các chỉ số tổng quan (8 Cards) -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 h-100 shadow-sm" style="background:linear-gradient(135deg, #ffffff, #fafafa);">
            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-uppercase fw-bold text-muted mb-1" style="font-size: .75rem; letter-spacing: 1px;">Sản phẩm</p>
                    <h3 class="fw-bolder text-dark mb-0">@Model.TotalProducts</h3>
                </div>
                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:50px;height:50px;background:#fff7ed;color:#ea580c;">
                    <i class="bi bi-box-seam fs-4"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 h-100 shadow-sm" style="background:linear-gradient(135deg, #ffffff, #fafafa);">
            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-uppercase fw-bold text-muted mb-1" style="font-size: .75rem; letter-spacing: 1px;">Người dùng</p>
                    <h3 class="fw-bolder text-dark mb-0">@Model.TotalUsers</h3>
                </div>
                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:50px;height:50px;background:#f0fdf4;color:#16a34a;">
                    <i class="bi bi-people fs-4"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 h-100 shadow-sm" style="background:linear-gradient(135deg, #ffffff, #fafafa);">
            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-uppercase fw-bold text-muted mb-1" style="font-size: .75rem; letter-spacing: 1px;">Lượt Upvote</p>
                    <h3 class="fw-bolder text-dark mb-0">@Model.TotalUpvotes</h3>
                </div>
                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:50px;height:50px;background:#fef2f2;color:#dc2626;">
                    <i class="bi bi-caret-up-fill fs-4"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 h-100 shadow-sm" style="background:linear-gradient(135deg, #ffffff, #fafafa);">
            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-uppercase fw-bold text-muted mb-1" style="font-size: .75rem; letter-spacing: 1px;">Bình luận</p>
                    <h3 class="fw-bolder text-dark mb-0">@Model.TotalComments</h3>
                </div>
                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:50px;height:50px;background:#eff6ff;color:#2563eb;">
                    <i class="bi bi-chat-dots fs-4"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Thống kê trạng thái & Bảng xếp hạng Topic -->
<div class="row g-4 mb-4">
    <!-- Cột Trái: Product Statuses -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4">
                <h6 class="fw-bold text-dark mb-0"><i class="bi bi-pie-chart me-2 text-muted"></i>Trạng thái Sản phẩm</h6>
            </div>
            <div class="card-body px-4 pb-4">
                @{
                    var tP = Model.TotalProducts == 0 ? 1 : Model.TotalProducts;
                    var pctApproved = (Model.TotalApprovedProducts * 100.0) / tP;
                    var pctPending = (Model.TotalPendingProducts * 100.0) / tP;
                    var pctRejected = (Model.TotalRejectedProducts * 100.0) / tP;
                    var pctHidden = (Model.TotalHiddenProducts * 100.0) / tP;
                }
                
                <div class="progress mb-4 mt-2" style="height: 1.5rem; border-radius: 12px; overflow: hidden; background: #f3f4f6;">
                    <div class="progress-bar fw-bold" style="width: @pctApproved%; background-color:#16a34a;" title="Approved: @Model.TotalApprovedProducts">
                        @(pctApproved > 5 ? $"{pctApproved:0.#}%" : "")
                    </div>
                    <div class="progress-bar fw-bold" style="width: @pctPending%; background-color:#ca8a04;" title="Pending: @Model.TotalPendingProducts">
                        @(pctPending > 5 ? $"{pctPending:0.#}%" : "")
                    </div>
                    <div class="progress-bar fw-bold" style="width: @pctRejected%; background-color:#dc2626;" title="Rejected: @Model.TotalRejectedProducts">
                        @(pctRejected > 5 ? $"{pctRejected:0.#}%" : "")
                    </div>
                    <div class="progress-bar fw-bold" style="width: @pctHidden%; background-color:#4b5563;" title="Hidden: @Model.TotalHiddenProducts">
                        @(pctHidden > 5 ? $"{pctHidden:0.#}%" : "")
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-4 mt-3">
                    <div class="d-flex align-items-center gap-2">
                        <span style="width:12px;height:12px;border-radius:3px;background:#16a34a;"></span>
                        <span class="text-muted fw-semibold small">Đã duyệt (@Model.TotalApprovedProducts)</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span style="width:12px;height:12px;border-radius:3px;background:#ca8a04;"></span>
                        <span class="text-muted fw-semibold small">Chờ duyệt (@Model.TotalPendingProducts)</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span style="width:12px;height:12px;border-radius:3px;background:#dc2626;"></span>
                        <span class="text-muted fw-semibold small">Bị từ chối (@Model.TotalRejectedProducts)</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span style="width:12px;height:12px;border-radius:3px;background:#4b5563;"></span>
                        <span class="text-muted fw-semibold small">Đã ẩn (@Model.TotalHiddenProducts)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Cột Phải: Top Topics -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4">
                <h6 class="fw-bold text-dark mb-0"><i class="bi bi-tags me-2 text-muted"></i>Top 5 Chủ đề nổi bật</h6>
            </div>
            <div class="card-body px-4 pb-4">
                @if(!Model.TopTopics.Any())
                {
                    <div class="text-center text-muted py-3">Chưa có dữ liệu chủ đề.</div>
                }
                @foreach (var topic in Model.TopTopics)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1" style="font-size:.85rem;">
                            <span class="fw-semibold text-dark">@topic.TopicName</span>
                            <span class="text-muted fw-bold">@topic.ProductCount SP (@topic.Percentage.ToString("0.0")%)</span>
                        </div>
                        <div class="progress" style="height: 6px; border-radius: 4px; background: #f3f4f6;">
                            <div class="progress-bar" role="progressbar" style="width: @topic.Percentage.ToString(System.Globalization.CultureInfo.InvariantCulture)%; background-color: var(--ph-orange); border-radius: 4px;"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Cấp 3: 3 Cột LEADERBOARDS -->
<div class="row g-4 mb-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
             <div class="card-header bg-white border-bottom px-4 py-3">
                 <h6 class="fw-bold mb-0 text-dark"><i class="bi bi-trophy text-warning me-2"></i>Top Sản Phẩm (Upvotes)</h6>
             </div>
             <div class="card-body p-0">
                 <ul class="list-group list-group-flush">
                     @foreach(var p in Model.TopProducts.Select((item, index) => new { index, item }))
                     {
                         <li class="list-group-item px-4 py-3 d-flex align-items-center gap-3">
                            <span class="fw-bold text-muted fs-5">#(p.index + 1)</span>
                            <img src="@(string.IsNullOrEmpty(p.item.LogoUrl) ? "/images/default-logo.png" : p.item.LogoUrl)" 
                                 class="rounded" style="width:36px;height:36px;object-fit:cover;">
                            <div class="flex-grow-1 min-w-0">
                                <a href="/Admin/Products/Detail/@p.item.ProductId" class="text-dark fw-semibold text-decoration-none d-block text-truncate" style="font-size:.9rem;">@p.item.ProductName</a>
                                <span class="d-flex align-items-center text-muted gap-1 mt-1 fw-bold" style="font-size:.8rem;">
                                    <i class="bi bi-caret-up-fill text-danger"></i> @p.item.UpvoteCount
                                </span>
                            </div>
                         </li>
                     }
                     @if(!Model.TopProducts.Any()) { <li class="list-group-item text-center text-muted py-4">Không có dữ liệu</li> }
                 </ul>
             </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
             <div class="card-header bg-white border-bottom px-4 py-3">
                 <h6 class="fw-bold mb-0 text-dark"><i class="bi bi-award text-primary me-2"></i>Top Makers (Số Sản Phẩm)</h6>
             </div>
             <div class="card-body p-0">
                 <ul class="list-group list-group-flush">
                     @foreach(var u in Model.TopMakers.Select((item, index) => new { index, item }))
                     {
                         <li class="list-group-item px-4 py-3 d-flex align-items-center gap-3">
                            <span class="fw-bold text-muted fs-5">#(u.index + 1)</span>
                            <div class="avatar rounded-circle d-flex align-items-center justify-content-center text-white fw-bold" style="width:36px;height:36px;background:#4b5563;font-size:1rem;">
                                @u.item.UserName.Substring(0,1).ToUpper()
                            </div>
                            <div class="flex-grow-1 min-w-0">
                                <a asp-area="" asp-controller="User" asp-action="Profile" asp-route-username="@u.item.UserName" target="_blank" class="text-dark fw-semibold text-decoration-none d-block text-truncate" style="font-size:.9rem;">@u.item.FullName</a>
                                <span class="d-flex align-items-center text-muted gap-1 mt-1 fw-bold" style="font-size:.8rem;">
                                    <i class="bi bi-box-seam"></i> @u.item.Count Sản phẩm
                                </span>
                            </div>
                         </li>
                     }
                     @if(!Model.TopMakers.Any()) { <li class="list-group-item text-center text-muted py-4">Không có dữ liệu</li> }
                 </ul>
             </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
             <div class="card-header bg-white border-bottom px-4 py-3">
                 <h6 class="fw-bold mb-0 text-dark"><i class="bi bi-star text-success me-2"></i>Top Nổi Bật (Followers)</h6>
             </div>
             <div class="card-body p-0">
                 <ul class="list-group list-group-flush">
                     @foreach(var u in Model.TopFollowedUsers.Select((item, index) => new { index, item }))
                     {
                         <li class="list-group-item px-4 py-3 d-flex align-items-center gap-3">
                            <span class="fw-bold text-muted fs-5">#(u.index + 1)</span>
                            <div class="avatar rounded-circle d-flex align-items-center justify-content-center text-white fw-bold" style="width:36px;height:36px;background:var(--ph-orange);font-size:1rem;">
                                @u.item.UserName.Substring(0,1).ToUpper()
                            </div>
                            <div class="flex-grow-1 min-w-0">
                                <a asp-area="" asp-controller="User" asp-action="Profile" asp-route-username="@u.item.UserName" target="_blank" class="text-dark fw-semibold text-decoration-none d-block text-truncate" style="font-size:.9rem;">@u.item.FullName</a>
                                <span class="d-flex align-items-center text-muted gap-1 mt-1 fw-bold" style="font-size:.8rem;">
                                    <i class="bi bi-person-heart"></i> @u.item.Count Người theo dõi
                                </span>
                            </div>
                         </li>
                     }
                     @if(!Model.TopFollowedUsers.Any()) { <li class="list-group-item text-center text-muted py-4">Không có dữ liệu</li> }
                 </ul>
             </div>
        </div>
    </div>
</div>

<!-- Pending products table -->
<div class="card border-0 shadow-sm mb-5">
    <div class="card-header bg-white border-bottom d-flex align-items-center justify-content-between py-3 px-4">
        <h6 class="fw-bold mb-0 text-dark">Sản phẩm chờ duyệt gần đây</h6>
        @if (Model.TotalPendingProducts > 0)
        {
            <a asp-controller="Products" asp-action="Pending" class="btn btn-sm btn-light border fw-semibold text-dark" style="font-size:.8rem;">
                Xem tất cả (@Model.TotalPendingProducts) <i class="bi bi-arrow-right ms-1"></i>
            </a>
        }
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Sản phẩm</th>
                        <th>Người đăng</th>
                        <th>Ngày nộp</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.RecentPendingProducts.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="bi bi-check2-all d-block mb-2" style="font-size:2rem;color:#d1d5db;"></i>
                                Không có sản phẩm nào đang chờ duyệt
                            </td>
                        </tr>
                    }
                    @foreach (var p in Model.RecentPendingProducts)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3 py-2">
                                    <img src="@(string.IsNullOrEmpty(p.LogoUrl) ? "/images/default-logo.png" : p.LogoUrl)"
                                         class="rounded" style="width:40px;height:40px;object-fit:cover;"
                                         onerror="this.src='https://placehold.co/40';">
                                    <div>
                                        <div class="fw-semibold text-dark" style="font-size:.9rem;">@p.ProductName</div>
                                        <div class="text-muted small">@p.Tagline</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <a asp-area="" asp-controller="User" asp-action="Profile" asp-route-username="@p.User.Username" target="_blank"
                                   class="text-decoration-none fw-semibold text-dark" style="font-size:.875rem;">@@@p.User.Username</a>
                            </td>
                            <td class="text-muted" style="font-size:.875rem;">@p.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end pe-4">
                                <a asp-controller="Products" asp-action="Detail" asp-route-id="@p.ProductId"
                                   class="btn btn-sm btn-dark fw-semibold px-3" style="border-radius: 6px;">Chi tiết & Duyệt</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
